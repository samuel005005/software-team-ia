# Cursor API (no commitear — copia a .env local)
CURSOR_API_KEY=

# Arquitectura y decisiones importantes
FACTORY_MODEL_SMART=composer-2.5

# Desarrollo normal
FACTORY_MODEL_FAST=composer-2.5-fast

# Tareas extremadamente simples
FACTORY_MODEL_CHEAP=composer-2.5-fast

# Fallback si no hay tier
FACTORY_MODEL=composer-2.5

# Optimización de tokens (defaults recomendados)
FACTORY_LEAN_PROMPT=1
FACTORY_SINGLE_SESSION=1
FACTORY_MAX_ANALYSIS_CHARS=4000
FACTORY_MAX_SPEC_CHARS=6000

# Auto-validación al completar fase (QA + Review + Security + gate)
FACTORY_AUTO_RELEASE=1
FACTORY_AUTO_RELEASE_REVIEW=1
FACTORY_AUTO_RELEASE_SECURITY=1
