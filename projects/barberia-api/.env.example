# Application
APP_NAME=Barberia API
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1

# Server (8001 evita conflicto si ya tienes otro servicio en 8000)
HOST=0.0.0.0
PORT=8001

# Database (5433 evita conflicto si ya tienes PostgreSQL en 5432)
DATABASE_URL=postgresql+psycopg2://barberia:barberia@localhost:5433/barberia

# Security (replace in production)
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
